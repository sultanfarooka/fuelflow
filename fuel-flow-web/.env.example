# API Configuration
# Relative URL → axios hits `<current-origin>/api/v1` and Vite's dev-server
# proxy (vite.config.ts → server.proxy) forwards to http://localhost:5035.
# Same-origin keeps auth cookies (SameSite=Lax) intact when the SPA is
# reached over localhost, LAN, Tailscale, or a phone via `vite --host`.
# Override with an absolute URL only when pointing at a non-proxied API.
VITE_API_BASE_URL=/api/v1

# Environment
VITE_ENV=development
