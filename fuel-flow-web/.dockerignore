# Dependencies & build output (rebuilt inside the image)
node_modules
dist
dev-dist

# Env files — the container build is driven solely by the VITE_API_BASE_URL build arg.
# Copying a local .env (which points at http://localhost:5035) would override it.
.env
.env.*

# Tests / tooling artifacts
playwright-report
test-results
.playwright-mcp
e2e-tests

