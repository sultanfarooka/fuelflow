# Copy to .env (git-ignored) and fill in real values before `docker compose up`.
# These are consumed by the root docker-compose.yml.

# PostgreSQL password for the `fuelflow` role (used by the db, api services).
POSTGRES_PASSWORD=fuelflow123

# JWT signing secret — MUST be at least 32 characters.
JWT_SECRET=change-me-to-a-random-secret-at-least-32-characters-long

# Pepper for hashing phone-OTP codes — use a long random string.
OTP_HASH_PEPPER=change-me-to-a-random-32-plus-character-pepper
